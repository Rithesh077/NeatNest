<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="NeatNest Onboarding"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="16dp"/>

        <!-- Permission Toggles -->
        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/switchNotifications"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Notification Access (Signal Noise)"
            android:padding="12dp"/>

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/switchBackground"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Allow Background Scanning"
            android:padding="12dp"
            android:layout_marginBottom="16dp"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#DDDDDD"
            android:layout_marginBottom="16dp"/>

        <!-- Scan Mode Selection -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Scanning Mode"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <RadioGroup
            android:id="@+id/rgScanMode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp">
            <RadioButton
                android:id="@+id/rbCompleteScan"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Complete Device Scan (All Files Access)"/>
            <RadioButton
                android:id="@+id/rbPickFolders"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pick specific folders to scan"/>
        </RadioGroup>

        <Button
            android:id="@+id/btnPickSourceFolders"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Select Folders to Scan"
            android:visibility="gone"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tvPickedFolders"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="No source folders selected"
            android:textSize="12sp"
            android:visibility="gone"
            android:layout_marginBottom="16dp"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#DDDDDD"
            android:layout_marginBottom="16dp"/>

        <!-- Target Root Selection -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Organization Destination"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btnSelectRoot"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Select Root Organization Folder"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tvRootPath"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="No destination folder selected"
            android:textSize="12sp"
            android:layout_marginBottom="16dp"/>

        <!-- Move vs Copy Toggle -->
        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/switchMoveFiles"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Move files (delete original) instead of copy"
            android:padding="12dp"
            android:layout_marginBottom="24dp"/>

        <Button
            android:id="@+id/btnStart"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Begin Ingestion &amp; Classification"
            android:padding="16dp"/>

        <ProgressBar
            android:id="@+id/progressBar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone"
            android:layout_marginTop="16dp"
            android:indeterminate="true" />

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Starting automated pipeline..."
            android:visibility="gone"
            android:layout_marginTop="8dp"/>

    </LinearLayout>
</ScrollView>
